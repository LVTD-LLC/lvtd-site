{
  "name": "lvtd-site",
  "private": true,
  "version": "0.1.0",
  "description": "LVTD org website",
  "devDependencies": {
    "@tailwindcss/cli": "4.1.13",
    "tailwindcss": "4.1.13"
  },
  "scripts": {
    "build:css": "tailwindcss -i ./assets/css/app.css -o ./static/css/app.css --minify --content \"./website/templates/**/*.html\"",
    "watch:css": "tailwindcss -i ./assets/css/app.css -o ./static/css/app.css --watch --content \"./website/templates/**/*.html\""
  }
}
